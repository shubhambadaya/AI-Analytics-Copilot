# Copy this file to `.streamlit/secrets.toml` for local use, OR paste these
# keys into the "Secrets" box of your Streamlit Community Cloud app settings.
# Do NOT commit the real secrets.toml — it is gitignored.

# Required: your Google Gemini API key (the app's default AI engine).
GEMINI_API_KEY = "your-gemini-api-key-here"

# Required for a shared/public deployment: the access password testers must enter.
# If left unset, the app runs without a password gate (fine for local dev).
APP_PASSWORD = "choose-a-shared-password"

# Optional: other providers, if you want them selectable.
# OPENAI_API_KEY = "..."
# ANTHROPIC_API_KEY = "..."
